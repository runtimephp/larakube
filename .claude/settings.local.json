{
  "permissions": {
    "allow": [
      "Bash(vendor/bin/pint --dirty --format agent)",
      "Bash(php artisan:*)",
      "Bash(vendor/bin/pest --type-coverage --min=0)",
      "Bash(vendor/bin/phpstan analyse:*)",
      "Bash(composer test:*)",
      "Bash(vendor/bin/pest --coverage --exactly=0)",
      "Bash(grep -E '\\(0\\\\.0%|[0-9]+\\\\.[0-9]%$\\)')"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "laravel-boost"
  ]
}
